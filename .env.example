# Server
PORT=3000
NODE_ENV=development

# ─── LOCAL DEVELOPMENT (MySQL) ───────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=sports_events

# ─── PRODUCTION (Render PostgreSQL) ──────────────────────────
# Render sets this automatically when a DB is attached.
# For local Postgres testing: postgres://user:pass@localhost:5432/sports_events
# DATABASE_URL=

# JWT
JWT_SECRET=your_super_secret_jwt_key_here
JWT_EXPIRES_IN=7d

# Session
SESSION_SECRET=your_session_secret_here

# Upload
MAX_FILE_SIZE=5242880
UPLOAD_PATH=public/images/uploads

# App
APP_URL=http://localhost:3000

# Email (SMTP) — optional
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@sportevent.ua
